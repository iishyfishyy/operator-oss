# Orchestrator — per-instance configuration.
# Every value is optional; the defaults below are what you get with no env set.
# This one set of variables fully relocates an instance (fresh container, other
# user, other ports) with zero code edits. Export them in the environment that
# launches `npm run dev` / `npm start` (server.js reads them before Next boots,
# so a .env file alone is not enough for PORT/HOSTNAME/PTY_*).

# ---- app server (server.js) ----
# Port + bind address for the single public origin (Next.js + /pty proxy).
PORT=3000
HOSTNAME=0.0.0.0

# ---- terminal sidecar (pty-server.js) ----
# The node-pty WebSocket sidecar. Keep it on loopback — the browser never
# connects directly; server.js proxies /pty upgrades to PTY_HOST:PTY_PORT.
PTY_PORT=3001
PTY_HOST=127.0.0.1

# ---- public origin ----
# The origin users reach the app on (e.g. https://orch.example.com behind a
# Cloudflare Tunnel / reverse proxy). The client builds its ws(s):// terminal
# URL from it. Leave empty to use the browser's own origin (window.location),
# which is correct for any single-hostname deployment.
PUBLIC_BASE_URL=

# ---- Cloudflare Access (origin-side auth; optional) ----
# If you expose an instance to the internet behind Cloudflare Access, these make
# the ORIGIN verify the same identity (the Cf-Access-Jwt-Assertion JWT) on every
# route AND on the /pty terminal WebSocket, so reaching the port directly grants
# nothing. Enforcement is ON iff BOTH are set — leave empty for local use.
#   CF_ACCESS_TEAM_DOMAIN: team domain, e.g. your-team.cloudflareaccess.com
#   CF_ACCESS_AUD:         the Access application's aud tag (comma-separable)
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=

# Shared secret letting health probes (Docker HEALTHCHECK, uptime monitors) read
# the service-token routes — GET /api/instance/idle, /api/version and
# /api/instance/usage, and ONLY those — without an Access JWT, via an
# `x-service-token: <value>` header. Generate with: openssl rand -hex 32
SERVICE_TOKEN=

# ---- product analytics (PostHog; optional) ----
# When POSTHOG_KEY is set the app renders the browser snippet AND emits
# server-side events (per-turn cost/tokens, project/task counts, heartbeat).
# No-ops when unset, so local/self-host runs need nothing here.
#   POSTHOG_KEY:        the project API key (phc_...). It's a write-only ingest
#                       key and safe to expose in the browser snippet.
#   POSTHOG_HOST:       ingest host, default https://us.i.posthog.com
#                       (use https://eu.i.posthog.com for the EU cloud).
#   ORCH_ACCOUNT_ID:    the distinct_id every event is keyed by. Leave blank for
#                       a standalone instance (falls back to "self-hosted").
POSTHOG_KEY=
POSTHOG_HOST=
ORCH_ACCOUNT_ID=

# ---- data locations ----
# SQLite app data (orchestrator.db) and per-task git worktrees. Both must live
# outside any project repo. Use absolute paths — `~` is NOT expanded.
# Defaults: $HOME/.zen-orchestrator and $HOME/.agent-orchestrator/worktrees.
ORCH_DB_DIR=
ORCH_WORKTREES_DIR=

# Where "New project → Clone from GitHub" puts cloned repos. Absolute path.
# Default: $HOME/projects.
ORCH_PROJECTS_DIR=

# ---- managed services ----
# Base of the deterministic per-project port block. Each project is assigned
# base + slot at creation (stored on projects.port) and that PORT is injected
# into its supervised dev/setup/test services and its PTY shell. Relocate to
# avoid clashing with the app/sidecar ports. Default: 4300.
ORCH_SERVICE_PORT_BASE=

# ---- claude binary ----
# Path to the logged-in `claude` CLI (Pro/Max). Pinned because Next's server may
# run with a trimmed PATH. Default: $HOME/.local/bin/claude.
CLAUDE_CLI_PATH=

# ---- codex binary ----
# Path to the `codex` CLI the Codex agent driver drives (ChatGPT-plan login).
# Empty = the SDK auto-resolves the binary bundled with @openai/codex, and the
# auth helpers fall back to `codex` on PATH (installed globally in the image).
# Set to pin a specific binary when PATH is trimmed. Default: (auto-resolve).
CODEX_CLI_PATH=

# ---- internal agent-tool bridge ----
# The loopback origin the stdio MCP bridge (scripts/orch-mcp.mjs, spawned by the
# Codex CLI per turn) uses to POST suggest_task / expose_service back to the app's
# internal endpoints. Authenticated with SERVICE_TOKEN. Empty = http://127.0.0.1
# on the app's own PORT, correct for the in-container default. Override only if
# the app is reached differently from inside the box.
ORCH_INTERNAL_BASE_URL=

# ---- agent credentials (usually NOT set here) ----
# The default, recommended path is subscription login done IN THE APP:
#   - Claude: onboarding / Settings "Connect Claude"   → login state in ~/.claude
#   - Codex:  Settings → Agents "Connect Codex" (device auth) → ~/.codex
# Both credential dirs live on the per-user home volume, so logins survive
# restarts with no env vars.
#
# The "I have an API key instead" paths persist their key to a 0600 file under
# ORCH_DB_DIR (anthropic-api-key / openai-api-key) and re-apply it to the process
# env on boot; you do NOT normally set these here. If you DO want to seed a key
# from the environment for a headless/dev instance, the app honors:
#   ANTHROPIC_API_KEY   billed per-token for Claude
#   OPENAI_API_KEY      billed per-token for Codex
# (Production entrypoints strip both from the container env as a hardening
# backstop, keeping the running process the only place a seeded key lives.)

# ---- per-instance resource caps (docker-compose.yml) ----
# What docker compose passes to the container runtime for THIS instance
# (--cpus / --memory). Defaults: 2 CPUs, 4g memory.
ORCH_CPUS=
ORCH_MEM=

# ---- feature flags (in-progress features; default OFF) ----
# PREVIEW tab (project live-URL view). Off until the remote-execution backend
# that actually runs/hosts the app and serves a real URL is in place. Set to 1
# to surface the tab in the session rail.
ORCH_FEATURE_LIVE_PREVIEW=

# Command palette: the toolbar "Jump to project, session, or command…" search
# bar and its ⌘K / Ctrl-K shortcut. Fuzzy-jumps to any project or session and
# runs common commands. Set to 1 to enable.
ORCH_FEATURE_OMNI_SEARCH=

# Managed Services — the toolbar "Services" button/drawer and the Services
# command config (dev/setup/test) block in the project-context editor. Set to 1
# to surface them. Also turns on public service hostnames: the persisted service
# registry with boot auto-restart, the host-header router in server.js
# (<slug>--<appHost> → 127.0.0.1:<port>), and per-service visibility
# (private/shared/public). Public URLs additionally need PUBLIC_BASE_URL (the
# router derives the instance's own hostname from it); without it services keep
# their honest http://localhost:<port> URLs.
ORCH_FEATURE_SERVICES=
