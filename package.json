{
  "name": "agent-orchestrator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n app,pty -c blue,green \"node server.js\" \"node pty-server.js\"",
    "dev:next": "node server.js",
    "pty": "node pty-server.js",
    "build": "NODE_ENV=production next build --turbopack",
    "start": "NODE_ENV=production concurrently -k -n app,pty -c blue,green \"node server.js\" \"node pty-server.js\"",
    "test": "vitest run",
    "postinstall": "node scripts/fix-pty.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.159",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@openai/codex-sdk": "^0.142.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^11.10.0",
    "highlight.js": "^11.11.1",
    "jose": "^6.2.3",
    "nanoid": "^5.1.11",
    "next": "15.5.18",
    "node-pty": "^1.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "ws": "^8.21.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "20.17.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "typescript": "5.8.2",
    "vitest": "^3.2.6"
  }
}
